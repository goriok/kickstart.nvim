 254: -- [[ Configure and install plugins ]]
 255: --
 256: --  To check the current status of your plugins, run
 257: --    :Lazy
 258: --
 259: --  You can press `?` in this menu for help. Use `:q` to close the window
 260: --
 261: --  To update plugins you can run
 262: --    :Lazy update
 263: --
 264: -- NOTE: Here is where you install your plugins.
 265: require('lazy').setup({
 266:   -- NOTE: Plugins can be added via a link or github org/name. To run setup automatically, use `opts = {}`
 267:   { 'NMAC427/guess-indent.nvim', opts = {} },
 268: 
 269:   -- Alternatively, use `config = function() ... end` for full control over the configuration.
 270:   -- If you prefer to call `setup` explicitly, use:
 271:   --    {
 272:   --        'lewis6991/gitsigns.nvim',
 273:   --        config = function()
 274:   --            require('gitsigns').setup({
 275:   --                -- Your gitsigns configuration here
 276:   --            })
 277:   --        end,
 278:   --    }
 279:   --
 280:   -- Here is a more advanced example where we pass configuration
 281:   -- options to `gitsigns.nvim`.
 282:   --
 283:   -- See `:help gitsigns` to understand what the configuration keys do
 284:   { -- Adds git related signs to the gutter, as well as utilities for managing changes
 285:     'lewis6991/gitsigns.nvim',
 286:     opts = {
 287:       signs = {
 288:         add = { text = '+' },
 289:         change = { text = '~' },
 290:         delete = { text = '_' },
 291:         topdelete = { text = '‾' },
 292:         changedelete = { text = '~' },
 293:       },
 294:     },
 295:   },
 296: 
 297:   -- NOTE: Plugins can also be configured to run Lua code when they are loaded.
 298:   --
 299:   -- This is often very useful to both group configuration, as well as handle
 300:   -- lazy loading plugins that don't need to be loaded immediately at startup.
 301:   --
 302:   -- For example, in the following configuration, we use:
 303:   --  event = 'VimEnter'
 304:   --
 305:   -- which loads which-key before all the UI elements are loaded. Events can be
 306:   -- normal autocommands events (`:help autocmd-events`).
 307:   --
 308:   -- Then, because we use the `opts` key (recommended), the configuration runs
 309:   -- after the plugin has been loaded as `require(MODULE).setup(opts)`.
 310: 
 311:   { -- Useful plugin to show you pending keybinds.
 312:     'folke/which-key.nvim',
 313:     event = 'VimEnter',
 314:     opts = {
 315:       -- delay between pressing a key and opening which-key (milliseconds)
 316:       delay = 0,
 317:       icons = { mappings = vim.g.have_nerd_font },
 318: 
 319:       -- Document existing key chains
 320:       spec = {
 321:         { '<leader>s', group = '[S]earch', mode = { 'n', 'v' } },
 322:         { '<leader>t', group = '[T]oggle' },
 323:         { '<leader>h', group = 'Git [H]unk', mode = { 'n', 'v' } },
 324:       },
 325:     },
 326:   },
 327: 
 328:   -- NOTE: Plugins can specify dependencies.
 329:   --
 330:   -- The dependencies are proper plugin specifications as well - anything
 331:   -- you do for a plugin at the top level, you can do for a dependency.
 332:   --
 333:   -- Use the `dependencies` key to specify the dependencies of a particular plugin
 334: 
 335:   { -- Fuzzy Finder (files, lsp, etc)
 336:     'nvim-telescope/telescope.nvim',
 337:     -- By default, Telescope is included and acts as your picker for everything.
 338: 
 339:     -- If you would like to switch to a different picker (like snacks, or fzf-lua)
 340:     -- you can disable the Telescope plugin by setting enabled to false and enable
 341:     -- your replacement picker by requiring it explicitly (e.g. 'custom.plugins.snacks')
 342: 
 343:     -- Note: If you customize your config for yourself,
 344:     -- it’s best to remove the Telescope plugin config entirely
 345:     -- instead of just disabling it here, to keep your config clean.
 346:     enabled = true,
 347:     event = 'VimEnter',
 348:     dependencies = {
 349:       'nvim-lua/plenary.nvim',
 350:       { -- If encountering errors, see telescope-fzf-native README for installation instructions
 351:         'nvim-telescope/telescope-fzf-native.nvim',
 352: 
 353:         -- `build` is used to run some command when the plugin is installed/updated.
 354:         -- This is only run then, not every time Neovim starts up.
 355:         build = 'make',
 356: 
 357:         -- `cond` is a condition used to determine whether this plugin should be
 358:         -- installed and loaded.
 359:         cond = function() return vim.fn.executable 'make' == 1 end,
 360:       },
 361:       { 'nvim-telescope/telescope-ui-select.nvim' },
 362: 
 363:       -- Useful for getting pretty icons, but requires a Nerd Font.
 364:       { 'nvim-tree/nvim-web-devicons', enabled = vim.g.have_nerd_font },
 365:     },
 366:     config = function()
 367:       -- Telescope is a fuzzy finder that comes with a lot of different things that
 368:       -- it can fuzzy find! It's more than just a "file finder", it can search
 369:       -- many different aspects of Neovim, your workspace, LSP, and more!
 370:       --
 371:       -- The easiest way to use Telescope, is to start by doing something like:
 372:       --  :Telescope help_tags
 373:       --
 374:       -- After running this command, a window will open up and you're able to
 375:       -- type in the prompt window. You'll see a list of `help_tags` options and
 376:       -- a corresponding preview of the help.
 377:       --
 378:       -- Two important keymaps to use while in Telescope are:
 379:       --  - Insert mode: <c-/>
 380:       --  - Normal mode: ?
 381:       --
 382:       -- This opens a window that shows you all of the keymaps for the current
 383:       -- Telescope picker. This is really useful to discover what Telescope can
 384:       -- do as well as how to actually do it!
 385: 
 386:       -- [[ Configure Telescope ]]
 387:       -- See `:help telescope` and `:help telescope.setup()`
 388:       require('telescope').setup {
 389:         -- You can put your default mappings / updates / etc. in here
 390:         --  All the info you're looking for is in `:help telescope.setup()`
 391:         --
 392:         -- defaults = {
 393:         --   mappings = {
 394:         --     i = { ['<c-enter>'] = 'to_fuzzy_refine' },
 395:         --   },
 396:         -- },
 397:         -- pickers = {}
 398:         extensions = {
 399:           ['ui-select'] = { require('telescope.themes').get_dropdown() },
 400:         },
 401:       }
 402: 
 403:       -- Enable Telescope extensions if they are installed
 404:       pcall(require('telescope').load_extension, 'fzf')
 405:       pcall(require('telescope').load_extension, 'ui-select')
 406: 
 407:       -- See `:help telescope.builtin`
 408:       local builtin = require 'telescope.builtin'
 409:       vim.keymap.set('n', '<leader>sh', builtin.help_tags, { desc = '[S]earch [H]elp' })
 410:       vim.keymap.set('n', '<leader>sk', builtin.keymaps, { desc = '[S]earch [K]eymaps' })
 411:       vim.keymap.set('n', '<leader>sf', builtin.find_files, { desc = '[S]earch [F]iles' })
 412:       vim.keymap.set('n', '<leader>ss', builtin.builtin, { desc = '[S]earch [S]elect Telescope' })
 413:       vim.keymap.set({ 'n', 'v' }, '<leader>sw', builtin.grep_string, { desc = '[S]earch current [W]ord' })
 414:       vim.keymap.set('n', '<leader>sg', builtin.live_grep, { desc = '[S]earch by [G]rep' })
 415:       vim.keymap.set('n', '<leader>sd', builtin.diagnostics, { desc = '[S]earch [D]iagnostics' })
 416:       vim.keymap.set('n', '<leader>sr', builtin.resume, { desc = '[S]earch [R]esume' })
 417:       vim.keymap.set('n', '<leader>s.', builtin.oldfiles, { desc = '[S]earch Recent Files ("." for repeat)' })
 418:       vim.keymap.set('n', '<leader>sc', builtin.commands, { desc = '[S]earch [C]ommands' })
 419:       vim.keymap.set('n', '<leader><leader>', builtin.buffers, { desc = '[ ] Find existing buffers' })
 420: 
 421:       -- This runs on LSP attach per buffer (see main LSP attach function in 'neovim/nvim-lspconfig' config for more info,
 422:       -- it is better explained there). This allows easily switching between pickers if you prefer using something else!
 423:       vim.api.nvim_create_autocmd('LspAttach', {
 424:         group = vim.api.nvim_create_augroup('telescope-lsp-attach', { clear = true }),
 425:         callback = function(event)
 426:           local buf = event.buf
 427: 
 428:           -- Find references for the word under your cursor.
 429:           vim.keymap.set('n', 'grr', builtin.lsp_references, { buffer = buf, desc = '[G]oto [R]eferences' })
 430: 
 431:           -- Jump to the implementation of the word under your cursor.
 432:           -- Useful when your language has ways of declaring types without an actual implementation.
 433:           vim.keymap.set('n', 'gri', builtin.lsp_implementations, { buffer = buf, desc = '[G]oto [I]mplementation' })
 434: 
 435:           -- Jump to the definition of the word under your cursor.
 436:           -- This is where a variable was first declared, or where a function is defined, etc.
 437:           -- To jump back, press <C-t>.
 438:           vim.keymap.set('n', 'grd', builtin.lsp_definitions, { buffer = buf, desc = '[G]oto [D]efinition' })
 439: 
 440:           -- Fuzzy find all the symbols in your current document.
 441:           -- Symbols are things like variables, functions, types, etc.
 442:           vim.keymap.set('n', 'gO', builtin.lsp_document_symbols, { buffer = buf, desc = 'Open Document Symbols' })
 443: 
 444:           -- Fuzzy find all the symbols in your current workspace.
 445:           -- Similar to document symbols, except searches over your entire project.
 446:           vim.keymap.set('n', 'gW', builtin.lsp_dynamic_workspace_symbols, { buffer = buf, desc = 'Open Workspace Symbols' })
 447: 
 448:           -- Jump to the type of the word under your cursor.
 449:           -- Useful when you're not sure what type a variable is and you want to see
 450:           -- the definition of its *type*, not where it was *defined*.
 451:           vim.keymap.set('n', 'grt', builtin.lsp_type_definitions, { buffer = buf, desc = '[G]oto [T]ype Definition' })
 452:         end,
 453:       })
 454: 
 455:       -- Override default behavior and theme when searching
 456:       vim.keymap.set('n', '<leader>/', function()
 457:         -- You can pass additional configuration to Telescope to change the theme, layout, etc.
 458:         builtin.current_buffer_fuzzy_find(require('telescope.themes').get_dropdown {
 459:           winblend = 10,
 460:           previewer = false,
 461:         })
 462:       end, { desc = '[/] Fuzzily search in current buffer' })
 463: 
 464:       -- It's also possible to pass additional configuration options.
 465:       --  See `:help telescope.builtin.live_grep()` for information about particular keys
 466:       vim.keymap.set(
 467:         'n',
 468:         '<leader>s/',
 469:         function()
 470:           builtin.live_grep {
 471:             grep_open_files = true,
 472:             prompt_title = 'Live Grep in Open Files',
 473:           }
 474:         end,
 475:         { desc = '[S]earch [/] in Open Files' }
 476:       )
