<file path="lua/custom/cc_budget.lua">
  1: -- lua/custom/cc_budget.lua
  2: -- Circuit breaker + turn tracking for CodeCompanion.
  3: -- Warns at WARN_AT turns, fires a hard notification at MAX_TURNS.
  4: -- Tracks active adapter/model per buffer for budget-aware statusline.
  5: -- Exposes M.statusline() for mini.statusline integration.
  6: -- Call M.setup() once during startup (see mini.nvim config in init.lua).
  7: 
  8: local M = {}
  9: 
 10: M.MAX_TURNS = 10
 11: M.WARN_AT = 7
 12: 
 13: -- state[bufnr] = { turns = n, warned = bool, adapter = string|nil, model = string|nil }
 14: local state = {}
 15: -- most recently focused codecompanion buffer (used as fallback by statusline)
 16: local last_cc_buf = nil
 17: 
 18: --- Resolve the codecompanion buffer from an autocmd event.
 19: --- Priority: ev.data.bufnr → last known CC buf → any visible CC win → current buf.
 20: local function resolve_buf(ev)
 21:   if ev and ev.data and type(ev.data.bufnr) == 'number' then return ev.data.bufnr end
 22:   if last_cc_buf and vim.api.nvim_buf_is_valid(last_cc_buf) then return last_cc_buf end
 23:   for _, win in ipairs(vim.api.nvim_list_wins()) do
 24:     local b = vim.api.nvim_win_get_buf(win)
 25:     if vim.bo[b].filetype == 'codecompanion' then return b end
 26:   end
 27:   return vim.api.nvim_get_current_buf()
 28: end
 29: 
 30: function M.setup()
 31:   local g = vim.api.nvim_create_augroup('CCBudget', { clear = true })
 32: 
 33:   -- Track the most recently active CC buffer for statusline fallback.
 34:   vim.api.nvim_create_autocmd('BufEnter', {
 35:     group = g,
 36:     callback = function(ev)
 37:       if vim.bo[ev.buf].filetype == 'codecompanion' then last_cc_buf = ev.buf end
 38:     end,
 39:   })
 40: 
 41:   -- Reset counter when a new chat is created.
 42:   vim.api.nvim_create_autocmd('User', {
 43:     group = g,
 44:     pattern = 'CodeCompanionChatCreated',
 45:     callback = function(ev)
 46:       local b = resolve_buf(ev)
 47:       state[b] = { turns = 0, warned = false }
 48:       last_cc_buf = b
 49:       vim.cmd.redrawstatus()
 50:     end,
 51:   })
 52: 
 53:   -- Increment counter on each request; track adapter/model; fire warnings.
 54:   vim.api.nvim_create_autocmd('User', {
 55:     group = g,
 56:     pattern = 'CodeCompanionRequestStarted',
 57:     callback = function(ev)
 58:       local b = resolve_buf(ev)
 59:       if not state[b] then state[b] = { turns = 0, warned = false } end
 60:       state[b].turns = state[b].turns + 1
 61:       local n = state[b].turns
 62: 
 63:       local adapter = ev.data and ev.data.adapter
 64:       if adapter then
 65:         state[b].adapter = adapter.name
 66:         state[b].model = adapter.model
 67:       end
 68: 
 69:       if n == M.MAX_TURNS then
 70:         vim.notify(
 71:           ('⛔ Circuit breaker: turn %d/%d\nContext rot risk — open a fresh chat (<leader>ac)'):format(n, M.MAX_TURNS),
 72:           vim.log.levels.ERROR,
 73:           { title = 'CC Budget' }
 74:         )
 75:       elseif n >= M.WARN_AT and not state[b].warned then
 76:         state[b].warned = true
 77:         vim.notify(
 78:           ('⚠  Turn %d/%d — %d left. Summarize context or start fresh soon.'):format(n, M.MAX_TURNS, M.MAX_TURNS - n),
 79:           vim.log.levels.WARN,
 80:           { title = 'CC Budget' }
 81:         )
 82:       end
 83: 
 84:       vim.cmd.redrawstatus()
 85:     end,
 86:   })
 87: 
 88:   -- Clean up state for deleted buffers.
 89:   vim.api.nvim_create_autocmd('BufDelete', {
 90:     group = g,
 91:     callback = function(ev)
 92:       state[ev.buf] = nil
 93:       if last_cc_buf == ev.buf then last_cc_buf = nil end
 94:     end,
 95:   })
 96: end
 97: 
 98: --- Shorten a model id for statusline display.
 99: --- "gpt-4.1" → "gpt-4.1", "claude-sonnet-4.5" → "sonnet-4.5"
100: ---@param model string
101: ---@return string
102: local function short_model(model)
103:   if not model or model == '' then return '' end
104:   -- strip common vendor prefixes
105:   return (model:gsub('^claude%-', ''):gsub('^gpt%-', 'gpt'))
106: end
107: 
108: --- Statusline component. Returns '' when there is no tracked CC session.
109: --- Format: icon T:n/max adapter(model)
110: --- Icons: 💬 normal · ⚠  approaching limit · ⛔ at limit
111: function M.statusline()
112:   local b = last_cc_buf
113:   if not b or not vim.api.nvim_buf_is_valid(b) then return '' end
114:   local s = state[b]
115:   if not s or s.turns == 0 then return '' end
116:   local n = s.turns
117:   local icon = n >= M.MAX_TURNS and '⛔' or n >= M.WARN_AT and '⚠ ' or '💬'
118:   local suffix = ''
119:   if s.adapter and s.model and s.model ~= '' then
120:     suffix = ' ' .. s.adapter .. '(' .. short_model(s.model) .. ')'
121:   elseif s.adapter then
122:     suffix = ' ' .. s.adapter
123:   end
124:   return ('%sT:%d/%d%s'):format(icon, n, M.MAX_TURNS, suffix)
125: end
126: 
127: --- Returns the raw turn count for a buffer (or last active CC buf).
128: ---@param bufnr? integer
129: ---@return integer turns, integer max_turns
130: function M.get_turns(bufnr)
131:   local b = bufnr or last_cc_buf
132:   if not b then return 0, M.MAX_TURNS end
133:   local s = state[b]
134:   return s and s.turns or 0, M.MAX_TURNS
135: end
136: 
137: --- Reset the counter for the given buffer (or the last active CC buffer).
138: ---@param bufnr? integer
139: function M.reset(bufnr)
140:   local b = bufnr or last_cc_buf
141:   if not b then
142:     vim.notify('No active CodeCompanion chat found', vim.log.levels.WARN)
143:     return
144:   end
145:   local prev = state[b]
146:   state[b] = { turns = 0, warned = false, adapter = prev and prev.adapter, model = prev and prev.model }
147:   vim.notify('CC Budget: counter reset for buf ' .. b, vim.log.levels.INFO, { title = 'CC Budget' })
148:   vim.cmd.redrawstatus()
149: end
150: 
151: return M
</file>

