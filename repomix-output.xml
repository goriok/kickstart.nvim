<file path="lua/custom/plugins/aerial.lua">
  1: -- aerial.nvim - Code outline and symbol navigation
  2: -- Shows the structure of your code (functions, classes, methods, etc) in a tree view.
  3: -- Great for navigating large files and understanding code structure at a glance.
  4: 
  5: return {
  6:   'stevearc/aerial.nvim',
  7:   opts = {
  8:     -- Automatically open aerial when entering a supported buffer
  9:     attach_mode = 'global',
 10: 
 11:     -- Open aerial in a split window
 12:     backends = { 'lsp', 'treesitter', 'markdown', 'man' },
 13: 
 14:     -- Window options
 15:     layout = {
 16:       -- max_width can be an integer (number of columns) or a float (percentage of window)
 17:       max_width = { 40, 0.25 },
 18:       width = 30,
 19:       min_width = 10,
 20: 
 21:       -- key-value pairs of window options for aerial window (e.g. winhl, colorcolumn)
 22:       win_opts = {},
 23: 
 24:       -- Determine the default direction to open the aerial window. The 'prefer'
 25:       -- options will open the window in the other direction *if* there is a
 26:       -- different buffer in the other window. Use the other options to always
 27:       -- open in the specified direction.
 28:       default_direction = 'prefer_right',
 29: 
 30:       -- Set this to an integer if you want to always open aerial on the left side
 31:       -- and want a fixed width.
 32:       -- Set this to a float if you want to always open aerial on the left side
 33:       -- and want a width percentage of the screen.
 34:       placement = 'window',
 35: 
 36:       -- When the symbols change, resize the aerial window (within the min/max constraints)
 37:       -- Set to false if you want a fixed size
 38:       preserve_equality = false,
 39:     },
 40: 
 41:     -- Icon configuration
 42:     nerd_font = vim.g.have_nerd_font,
 43: 
 44:     -- Show icons for the symbols
 45:     icons = {},
 46: 
 47:     -- Display options
 48:     show_guides = true,
 49: 
 50:     -- Keymaps in the aerial buffer. Use the command name, not the mapping string.
 51:     keymaps = {
 52:       ['?'] = 'actions.show_help',
 53:       ['g?'] = 'actions.show_help',
 54:       ['<CR>'] = 'actions.jump',
 55:       ['<2-LeftMouse>'] = 'actions.jump',
 56:       ['-'] = 'actions.close',
 57:       ['o'] = 'actions.jump',
 58:       ['h'] = 'actions.prev',
 59:       ['j'] = 'actions.next',
 60:       ['k'] = 'actions.prev',
 61:       ['l'] = 'actions.next',
 62:       ['{'] = 'actions.prev_up',
 63:       ['}'] = 'actions.next_up',
 64:       ['[['] = 'actions.prev_up',
 65:       [']]'] = 'actions.next_up',
 66:       ['q'] = 'actions.close',
 67:       ['v'] = 'actions.visual',
 68:       ['V'] = 'actions.visual_line',
 69:       ['<C-v>'] = 'actions.visual_block',
 70:     },
 71: 
 72:     -- Call this function when aerial attaches to a buffer.
 73:     on_attach = function(bufnr)
 74:       -- Jump back to aerial window if we are in a different window
 75:       vim.keymap.set('n', '{', '<cmd>AerialPrev<CR>', { buffer = bufnr, nowait = true })
 76:       vim.keymap.set('n', '}', '<cmd>AerialNext<CR>', { buffer = bufnr, nowait = true })
 77:     end,
 78: 
 79:     -- A list of all the characters that will be used to render guides
 80:     guides = {
 81:       mid_item = '├─ ',
 82:       last_item = '└─ ',
 83:       nested_top = '│ ',
 84:       whitespace = '  ',
 85:     },
 86:   },
 87:   -- Optional dependencies
 88:   dependencies = {
 89:     'nvim-treesitter/nvim-treesitter',
 90:     'nvim-tree/nvim-web-devicons',
 91:   },
 92: 
 93:   config = function(_, opts)
 94:     require('aerial').setup(opts)
 95: 
 96:     -- Keymaps for opening aerial
 97:     vim.keymap.set('n', '<leader>ts', '<cmd>AerialToggle!<CR>', { desc = '[T]oggle [S]ymbols (Aerial)' })
 98:     vim.keymap.set('n', '<leader>tS', '<cmd>AerialToggleAll<CR>', { desc = '[T]oggle [S]ymbols for all buffers' })
 99: 
100:     -- Keymaps for navigation
101:     vim.keymap.set('n', 'gO', function()
102:       -- Use telescope if available to search symbols, otherwise use aerial
103:       pcall(function() require('telescope.builtin').lsp_document_symbols() end)
104:     end, { desc = '[G]oto [O]utline (Document Symbols)' })
105: 
106:     -- Optional: Highlight the symbol at the cursor
107:     vim.api.nvim_create_autocmd('CursorMoved', {
108:       callback = function()
109:         if vim.fn.exists ':AerialInfo' == 2 then
110:           pcall(function() require('aerial').sync_highlight() end)
111:         end
112:       end,
113:     })
114:   end,
115: }
</file>

