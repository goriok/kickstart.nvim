<file path="lua/custom/plugins/toggleterm.lua">
 1: return {
 2:   'akinsho/toggleterm.nvim',
 3:   version = '*',
 4:   keys = {
 5:     { '<leader>tt', desc = '[T]oggle [T]erminal (horizontal)' },
 6:     { '<leader>tf', desc = '[T]oggle [T]erminal (float)' },
 7:     { '<leader>tv', desc = '[T]oggle [T]erminal (vertical)' },
 8:   },
 9:   opts = {
10:     size = function(term)
11:       if term.direction == 'horizontal' then
12:         return 15
13:       elseif term.direction == 'vertical' then
14:         return vim.o.columns * 0.4
15:       end
16:     end,
17:     open_mapping = false, -- Gerenciamos os keymaps manualmente
18:     shade_terminals = true,
19:     shading_factor = 2,
20:     start_in_insert = true,
21:     persist_size = true,
