  1: -- debug.lua
  2: --
  3: -- Shows how to use the DAP plugin to debug your code.
  4: --
  5: -- Primarily focused on configuring the debugger for Go, but can
  6: -- be extended to other languages as well. That's why it's called
  7: -- kickstart.nvim and not kitchen-sink.nvim ;)
  8: 
  9: return {
 10:   -- NOTE: Yes, you can install new plugins here!
 11:   'mfussenegger/nvim-dap',
 12:   -- NOTE: And you can specify dependencies as well
 13:   dependencies = {
 14:     -- Creates a beautiful debugger UI
 15:     'rcarriga/nvim-dap-ui',
 16: 
 17:     -- Required dependency for nvim-dap-ui
 18:     'nvim-neotest/nvim-nio',
 19: 
 20:     -- Installs the debug adapters for you
 21:     'mason-org/mason.nvim',
 22:     'jay-babu/mason-nvim-dap.nvim',
 23: 
 24:     -- Add your own debuggers here
 25:     'leoluz/nvim-dap-go',
 26:   },
 27:   keys = {
 28:     -- Basic debugging keymaps, feel free to change to your liking!
 29:     {
 30:       '<F5>',
 31:       function() require('dap').continue() end,
 32:       desc = 'Debug: Start/Continue',
 33:     },
 34:     {
 35:       '<F1>',
 36:       function() require('dap').step_into() end,
 37:       desc = 'Debug: Step Into',
 38:     },
 39:     {
 40:       '<F2>',
 41:       function() require('dap').step_over() end,
 42:       desc = 'Debug: Step Over',
 43:     },
 44:     {
 45:       '<F3>',
 46:       function() require('dap').step_out() end,
 47:       desc = 'Debug: Step Out',
 48:     },
 49:     {
 50:       '<leader>b',
 51:       function() require('dap').toggle_breakpoint() end,
 52:       desc = 'Debug: Toggle Breakpoint',
 53:     },
 54:     {
 55:       '<leader>B',
 56:       function() require('dap').set_breakpoint(vim.fn.input 'Breakpoint condition: ') end,
 57:       desc = 'Debug: Set Breakpoint',
 58:     },
 59:     -- Toggle to see last session result. Without this, you can't see session output in case of unhandled exception.
 60:     {
 61:       '<F7>',
 62:       function() require('dapui').toggle() end,
 63:       desc = 'Debug: See last session result.',
 64:     },
 65:   },
 66:   config = function()
 67:     local dap = require 'dap'
 68:     local dapui = require 'dapui'
 69: 
 70:     require('mason-nvim-dap').setup {
 71:       -- Makes a best effort to setup the various debuggers with
 72:       -- reasonable debug configurations
 73:       automatic_installation = true,
 74: 
 75:       -- You can provide additional configuration to the handlers,
 76:       -- see mason-nvim-dap README for more information
 77:       handlers = {},
 78: 
 79:       -- You'll need to check that you have the required things installed
 80:       -- online, please don't ask me how to install them :)
 81:       ensure_installed = {
 82:         -- Update this to ensure that you have the debuggers for the langs you want
 83:         'delve',
 84:       },
 85:     }
 86: 
 87:     -- Dap UI setup
 88:     -- For more information, see |:help nvim-dap-ui|
 89:     dapui.setup {
 90:       -- Set icons to characters that are more likely to work in every terminal.
 91:       --    Feel free to remove or use ones that you like more! :)
 92:       --    Don't feel like these are good choices.
 93:       icons = { expanded = '▾', collapsed = '▸', current_frame = '*' },
 94:       controls = {
 95:         icons = {
 96:           pause = '⏸',
 97:           play = '▶',
 98:           step_into = '⏎',
 99:           step_over = '⏭',
100:           step_out = '⏮',
101:           step_back = 'b',
102:           run_last = '▶▶',
103:           terminate = '⏹',
104:           disconnect = '⏏',
105:         },
106:       },
107:     }
108: 
109:     -- Change breakpoint icons
110:     -- vim.api.nvim_set_hl(0, 'DapBreak', { fg = '#e51400' })
111:     -- vim.api.nvim_set_hl(0, 'DapStop', { fg = '#ffcc00' })
