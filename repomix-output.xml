 9:     sign_priority = 8,
10:     keywords = {
11:       FIX  = { icon = ' ', color = 'error',   alt = { 'FIXME', 'BUG', 'FIXIT', 'ISSUE' } },
12:       TODO = { icon = ' ', color = 'info' },
13:       HACK = { icon = ' ', color = 'warning' },
14:       WARN = { icon = ' ', color = 'warning', alt = { 'WARNING', 'XXX' } },
15:       PERF = { icon = '󰥔 ', color = 'default', alt = { 'OPTIM', 'PERFORMANCE', 'OPTIMIZE' } },
16:       NOTE = { icon = '󰎞 ', color = 'hint',    alt = { 'INFO', 'NOTES' } },
17:       TEST = { icon = '⏲ ', color = 'test',    alt = { 'TESTING', 'PASSED', 'FAILED' } },
18:     },
19:     -- stylua: ignore
20:     highlight = {
21:       multiline         = true,   -- enable multine todo comments
22:       multiline_pattern = '^.',   -- lua pattern to match the next multiline from the start of the matched keyword
23:       multiline_context = 10,     -- extra lines that will be re-evaluated when changing a line
