 478:       -- Shortcut for searching your Neovim configuration files
 479:       vim.keymap.set('n', '<leader>sn', function() builtin.find_files { cwd = vim.fn.stdpath 'config' } end, { desc = '[S]earch [N]eovim files' })
 480:     end,
 481:   },
 482: 
 483:   -- LSP Plugins
 484:   {
 485:     -- Main LSP Configuration
 486:     'neovim/nvim-lspconfig',
 487:     dependencies = {
 488:       -- Automatically install LSPs and related tools to stdpath for Neovim
 489:       -- Mason must be loaded before its dependents so we need to set it up here.
 490:       -- NOTE: `opts = {}` is the same as calling `require('mason').setup({})`
 491:       { 'mason-org/mason.nvim', opts = {} },
 492:       'WhoIsSethDaniel/mason-tool-installer.nvim',
 493: 
 494:       -- Useful status updates for LSP.
 495:       {
 496:         'j-hui/fidget.nvim',
 497:         opts = {
 498:           notification = {
 499:             override_vim_notify = true,
 500:             window = {
 501:               winblend = 0,
 502:               relative = 'editor',
 503:               x_padding = 1,
 504:               y_padding = 0,
 505:               align = 'top',
 506:               border = 'none',
 507:             },
 508:           },
 509:         },
 510:       },
 511: 
 512:       -- Allows extra capabilities provided by blink.cmp
 513:       'saghen/blink.cmp',
 514:     },
 515:     config = function()
 516:       -- Brief aside: **What is LSP?**
 517:       --
 518:       -- LSP is an initialism you've probably heard, but might not understand what it is.
 519:       --
 520:       -- LSP stands for Language Server Protocol. It's a protocol that helps editors
 521:       -- and language tooling communicate in a standardized fashion.
 522:       --
 523:       -- In general, you have a "server" which is some tool built to understand a particular
 524:       -- language (such as `gopls`, `lua_ls`, `rust_analyzer`, etc.). These Language Servers
 525:       -- (sometimes called LSP servers, but that's kind of like ATM Machine) are standalone
 526:       -- processes that communicate with some "client" - in this case, Neovim!
 527:       --
 528:       -- LSP provides Neovim with features like:
 529:       --  - Go to definition
 530:       --  - Find references
 531:       --  - Autocompletion
 532:       --  - Symbol Search
 533:       --  - and more!
 534:       --
 535:       -- Thus, Language Servers are external tools that must be installed separately from
 536:       -- Neovim. This is where `mason` and related plugins come into play.
 537:       --
 538:       -- If you're wondering about lsp vs treesitter, you can check out the wonderfully
 539:       -- and elegantly composed help section, `:help lsp-vs-treesitter`
 540: 
 541:       --  This function gets run when an LSP attaches to a particular buffer.
 542:       --    That is to say, every time a new file is opened that is associated with
 543:       --    an lsp (for example, opening `main.rs` is associated with `rust_analyzer`) this
 544:       --    function will be executed to configure the current buffer
 545:       vim.api.nvim_create_autocmd('LspAttach', {
 546:         group = vim.api.nvim_create_augroup('kickstart-lsp-attach', { clear = true }),
 547:         callback = function(event)
 548:           -- NOTE: Remember that Lua is a real programming language, and as such it is possible
 549:           -- to define small helper and utility functions so you don't have to repeat yourself.
 550:           --
 551:           -- In this case, we create a function that lets us more easily define mappings specific
 552:           -- for LSP related items. It sets the mode, buffer and description for us each time.
 553:           local map = function(keys, func, desc, mode)
 554:             mode = mode or 'n'
 555:             vim.keymap.set(mode, keys, func, { buffer = event.buf, desc = 'LSP: ' .. desc })
 556:           end
 557: 
 558:           -- Rename the variable under your cursor.
 559:           --  Most Language Servers support renaming across files, etc.
 560:           map('grn', vim.lsp.buf.rename, '[R]e[n]ame')
 561: 
 562:           -- Execute a code action, usually your cursor needs to be on top of an error
 563:           -- or a suggestion from your LSP for this to activate.
 564:           map('gra', vim.lsp.buf.code_action, '[G]oto Code [A]ction', { 'n', 'x' })
 565: 
 566:           -- WARN: This is not Goto Definition, this is Goto Declaration.
 567:           --  For example, in C this would take you to the header.
 568:           map('grD', vim.lsp.buf.declaration, '[G]oto [D]eclaration')
 569: 
 570:           -- The following two autocommands are used to highlight references of the
 571:           -- word under your cursor when your cursor rests there for a little while.
 572:           --    See `:help CursorHold` for information about when this is executed
 573:           --
 574:           -- When you move your cursor, the highlights will be cleared (the second autocommand).
 575:           local client = vim.lsp.get_client_by_id(event.data.client_id)
 576:           if client and client:supports_method('textDocument/documentHighlight', event.buf) then
 577:             local highlight_augroup = vim.api.nvim_create_augroup('kickstart-lsp-highlight', { clear = false })
 578:             vim.api.nvim_create_autocmd({ 'CursorHold', 'CursorHoldI' }, {
 579:               buffer = event.buf,
 580:               group = highlight_augroup,
 581:               callback = vim.lsp.buf.document_highlight,
 582:             })
 583: 
 584:             vim.api.nvim_create_autocmd({ 'CursorMoved', 'CursorMovedI' }, {
 585:               buffer = event.buf,
 586:               group = highlight_augroup,
 587:               callback = vim.lsp.buf.clear_references,
 588:             })
 589: 
 590:             vim.api.nvim_create_autocmd('LspDetach', {
